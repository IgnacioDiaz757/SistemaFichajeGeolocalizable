# Copiá este archivo como .env para desarrollo local
# En Vercel, configurá estas variables en Settings → Environment Variables

# Supabase (obtenelas en https://supabase.com → tu proyecto → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...tu_clave_anonima...

# Admin panel
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esto_por_una_contraseña_segura
